{
  "name": "astro-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=--use-system-ca next dev",
    "build": "NODE_OPTIONS=--use-system-ca next build",
    "start": "NODE_OPTIONS=--use-system-ca next start",
    "lint": "next lint",
    "start:cli": "NODE_OPTIONS=--use-system-ca node src/index.js",
    "start:topocentric": "NODE_OPTIONS=--use-system-ca node src/index.js topocentric",
    "start:houses": "NODE_OPTIONS=--use-system-ca node src/index.js houses",
    "start:houses:topocentric": "NODE_OPTIONS=--use-system-ca node src/index.js houses topocentric",
    "docker:up": "docker compose up -d --build",
    "docker:mongo": "docker compose -f docker-compose.dev.yml up -d",
    "docker:mongo:down": "docker compose -f docker-compose.dev.yml down",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:run": "docker compose run --rm app node src/index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "gigachat": "^0.0.14",
    "jose": "^5.9.6",
    "langfuse": "^3.37.0",
    "mongoose": "^8.9.0",
    "next": "^14.2.28",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.2"
  }
}
